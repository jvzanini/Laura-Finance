# PostgreSQL (docker-compose default)
POSTGRES_USER=laura
POSTGRES_PASSWORD=YOUR_PASSWORD
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DB=laura_finance

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET

# Resend email (https://resend.com/api-keys)
RESEND_API_KEY=re_YOUR_KEY

# Laura Go API (optional — PWA works without it via direct Postgres)
# LAURA_GO_API_URL=http://localhost:8080

# Sessão HMAC — compartilhada com laura-go (mesmo valor).
SESSION_SECRET=GENERATE_WITH_openssl_rand_base64_32

# URL pública da app (usada em links de email e return_url do Stripe Portal).
NEXT_PUBLIC_APP_URL=http://localhost:3100

# Stripe Billing Portal return URL (default: NEXT_PUBLIC_APP_URL/subscription).
# STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:3100/subscription

# Em CI/E2E, OTPs aceitam código fixo 123456 (precisa bater com laura-go).
OTP_TEST_MODE=false
