# Postgres connection string (docker-compose default)
DATABASE_URL=postgres://laura:YOUR_PASSWORD@localhost:5433/laura_finance?sslmode=disable

# Groq API key (https://console.groq.com/keys)
GROQ_API_KEY=gsk_YOUR_KEY_HERE

# HTTP server port
PORT=8080

# Sessão (HMAC-SHA256). Mínimo 32 bytes aleatórios. Em prod, ausência = crash.
# Gerar com: openssl rand -base64 32
SESSION_SECRET=GENERATE_WITH_openssl_rand_base64_32

# OpenAI fallback (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-YOUR_KEY_HERE

# Google Gemini fallback (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=AIza_YOUR_KEY_HERE

# Stripe (live ou test) (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET

# Resend (email) (https://resend.com/api-keys)
RESEND_API_KEY=re_YOUR_KEY

# Ambiente: development | production
APP_ENV=development

# DISABLE_WHATSAPP=true desabilita init whatsmeow (CI/E2E).
DISABLE_WHATSAPP=false

# MIGRATE_ON_BOOT=true roda migrate up via embed.FS no boot.
MIGRATE_ON_BOOT=false

# Flag rollback Fase 13: força ChatCompletion sem ctx (legacy).
# Default false. Remover após validação prod (~T+30d Fase 14).
LLM_LEGACY_NOCONTEXT=false

# LLM ping no /ready (default disabled para evitar custos).
LLM_PING_DISABLED=true

# ═══════════════════════════════════════════════════════════════
# Open Finance (Fase 13 foundation — STANDBY)
# ═══════════════════════════════════════════════════════════════
# Secrets ficam em fly secrets em produção; local opcional.
PLUGGY_CLIENT_ID=           # [STANDBY]
PLUGGY_CLIENT_SECRET=       # [STANDBY]

# Feature flag: 'on' ativa sync diário (workflow bank-sync.yml).
FEATURE_BANK_SYNC=off

# --- Pluggy Webhooks (Fase 15) ---
PLUGGY_WEBHOOK_SECRET=           # [STANDBY] secret HMAC do dashboard Pluggy
PLUGGY_WEBHOOK_SECRET_OLD=       # opcional — grace period de rotação
FEATURE_PLUGGY_WEBHOOKS=false    # true habilita handler + worker

# --- Cache pub/sub cross-instance (Fase 15) ---
CACHE_PUBSUB_DISABLED=false      # true desativa pub/sub (single-instance)

# ═══════════════════════════════════════════════════════════════
# Fase 18 — assinatura, trial, OTP
# ═══════════════════════════════════════════════════════════════
# HMAC-SHA256 do código OTP. Gerar com: openssl rand -hex 32. Obrigatório em prod.
OTP_SECRET=GENERATE_WITH_openssl_rand_hex_32

# Dias de trial grátis no signup (default 7).
TRIAL_DAYS=7

# Dias de grace após invoice.payment_failed antes de bloquear (default 3).
PAST_DUE_GRACE_DAYS=3

# Em CI/E2E, aceita código fixo 123456 no VerifyOTP. NÃO ligar em prod.
OTP_TEST_MODE=false

# Instância WhatsApp usada para enviar OTPs (opcional).
# Se vazio, usa primeira instância com status=connected.
WHATSAPP_OTP_INSTANCE_ID=

# Sender email (sobrescreve system_config se preenchido).
EMAIL_SENDER_NAME=Laura Finance
EMAIL_SENDER=onboarding@resend.dev

# URL pública da app (usado em templates de email como {{app_url}}).
APP_URL=http://localhost:3100
