# Laura Finance — variáveis de ambiente consolidadas (raiz do projeto).
# Para devs: copie para .env.local, NUNCA commitar.
# Para deploy: usar Fly secrets (Go) + Vercel env (PWA).

# ═══════════════════════════════════════════════════════════════
# Banco de dados (Postgres + pgvector)
# ═══════════════════════════════════════════════════════════════
POSTGRES_USER=laura
POSTGRES_PASSWORD=GENERATE_LOCAL_PASSWORD
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DB=laura_finance
DATABASE_URL=postgres://laura:GENERATE_LOCAL_PASSWORD@127.0.0.1:5433/laura_finance?sslmode=disable

# ═══════════════════════════════════════════════════════════════
# Backend Go (laura-go)
# ═══════════════════════════════════════════════════════════════
PORT=8080
APP_ENV=development
ENVIRONMENT=development
LOG_LEVEL=info
TZ=America/Sao_Paulo

# Sessão (HMAC-SHA256). Mínimo 32 bytes aleatórios. Em prod, ausência = crash.
# Gerar com: openssl rand -hex 32
SESSION_SECRET=GENERATE_WITH_openssl_rand_hex_32

# Migrations no boot via embed.FS + golang-migrate.
MIGRATE_ON_BOOT=false

# Whatsapp client (CI/E2E desabilita)
DISABLE_WHATSAPP=false

# LLM providers (multi-provider)
GROQ_API_KEY=gsk_YOUR_KEY_HERE
OPENAI_API_KEY=sk-YOUR_KEY_HERE
GOOGLE_API_KEY=AIza_YOUR_KEY_HERE

# Pagamentos
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET

# Email
RESEND_API_KEY=re_YOUR_KEY

# ═══════════════════════════════════════════════════════════════
# Frontend PWA (laura-pwa)
# ═══════════════════════════════════════════════════════════════
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_NAME="Laura Finance"

# ═══════════════════════════════════════════════════════════════
# E2E Playwright (CI)
# ═══════════════════════════════════════════════════════════════
BASE_URL=http://localhost:3100
API_URL=http://localhost:8080
E2E_USER_EMAIL=e2e@laura.test
E2E_USER_PASSWORD=e2epass123!
