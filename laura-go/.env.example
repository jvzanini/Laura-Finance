# Postgres connection string (docker-compose default)
DATABASE_URL=postgres://laura:YOUR_PASSWORD@localhost:5433/laura_finance?sslmode=disable

# Groq API key (https://console.groq.com/keys)
GROQ_API_KEY=gsk_YOUR_KEY_HERE

# HTTP server port
PORT=8080

# Sessão (HMAC-SHA256). Mínimo 32 bytes aleatórios. Em prod, ausência = crash.
# Gerar com: openssl rand -base64 32
SESSION_SECRET=GENERATE_WITH_openssl_rand_base64_32

# OpenAI fallback (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-YOUR_KEY_HERE

# Google Gemini fallback (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=AIza_YOUR_KEY_HERE

# Stripe (live ou test) (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET

# Resend (email) (https://resend.com/api-keys)
RESEND_API_KEY=re_YOUR_KEY

# Ambiente: development | production
APP_ENV=development

# DISABLE_WHATSAPP=true desabilita init whatsmeow (CI/E2E).
DISABLE_WHATSAPP=false
